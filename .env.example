# 复制为 .env 后填写（仓库根目录）。main.py 启动时会通过 mtcmb_env.load_dotenv() 加载。
# 已存在于系统环境中的变量不会被 .env 覆盖。

# ---------- OpenAI 兼容 API（make_answer/chat/remote/openai_api.py）----------
OPENAI_API_KEY=sk-your-api-key
OPENAI_BASE_URL=https://api.openai.com/v1

# ---------- OpenRouter（make_answer/chat/remote/openrouter_api.py）----------
OPENROUTER_API_KEY=sk-or-your-api-key
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_HTTP_REFERER=https://github.com/Wayyuanyuan/MTCMB
OPENROUTER_SITE_TITLE=MTCMB
OPENROUTER_MAX_TOKENS=4096
OPENROUTER_MAX_RETRIES=3
OPENROUTER_RETRY_SLEEP=3

# ---------- DeepSeek（scripts/build_tcm_ft_enriched_deepseek.py）----------
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-reasoner

# ---------- 本地 HuggingFace 模型路径（--model-type 使用）----------
LOCAL_MODEL_TAIYI=/path/to/Taiyi-LLM
LOCAL_MODEL_WINGPT2=/path/to/WiNGPT2
LOCAL_MODEL_HUATUO=/path/to/HuatuoGPT-II
LOCAL_MODEL_BAICHUAN=/path/to/Baichuan-M1
LOCAL_MODEL_DISC_MEDLLM=/path/to/DISC-MedLLM
